# ─────────────────────────────────────────────────────────────
# Flowise — Pilotage SMQ — Variables d'environnement (exemple)
# Copier ce fichier en `.env.local` et renseigner les valeurs.
# NE JAMAIS committer `.env.local` ni de secrets réels.
# ─────────────────────────────────────────────────────────────

# --- Supabase (projet région Frankfurt / eu-central-1) ---
# Exposées au navigateur (préfixe NEXT_PUBLIC_), non sensibles :
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Secret serveur — NE JAMAIS exposer côté client ni committer :
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Secrets pour la CLI Supabase (migrations / génération de types) — locaux uniquement :
# - Personal Access Token : https://supabase.com/dashboard/account/tokens
# - Mot de passe DB : défini à la création du projet (réinitialisable dans Settings > Database)
SUPABASE_ACCESS_TOKEN="sbp_..."
SUPABASE_DB_PASSWORD=""

# --- Resend (email transactionnel) ---
# Tant que RESEND_API_KEY est vide, aucun e-mail n'est envoyé (no-op) ; les
# notifications in-app continuent de fonctionner. Pour activer :
#  1. Créer une clé API sur https://resend.com
#  2. Vérifier un domaine d'envoi, puis renseigner RESEND_FROM avec ce domaine.
RESEND_API_KEY="re_..."
# Expéditeur affiché. Par défaut "onboarding@resend.dev" (envoi de test sans domaine vérifié).
RESEND_FROM="Flowise Qualité <qualite@mondomaine.fr>"

# --- BoondManager OAuth 2.0 (Phase 3) ---
BOOND_CLIENT_ID=""
BOOND_CLIENT_SECRET=""
BOOND_AUTHORIZATION_URL="https://ui.boondmanager.com/oauth2/authorize"
BOOND_ACCESS_TOKEN_URL="https://api.boondmanager.com/oauth2/token"
BOOND_REDIRECT_URI="http://localhost:3000/api/boond/callback"

# --- Application ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
